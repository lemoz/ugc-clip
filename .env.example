# ── Server ──────────────────────────────────────────────────────
UGC_HOST=127.0.0.1
UGC_PORT=8000
UGC_SECRET_KEY=change-me-to-a-random-secret

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/ugc_clip.db

# ── Auth ───────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── LLM ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── TTS (Qwen3-TTS on GCP GPU) ────────────────────────────────
GCP_PROJECT_ID=
GCP_ZONE=us-central1-a
GCP_MACHINE_TYPE=g2-standard-4
GCP_GPU_TYPE=nvidia-l4
GCP_GPU_COUNT=1
GCP_IMAGE_PROJECT=deeplearning-platform-release
GCP_IMAGE=pytorch-2-7-cu128-ubuntu-2204-nvidia-570-v20260129
QWEN_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_DTYPE=float32
QWEN_ATTN_IMPLEMENTATION=
QWEN_LANGUAGE=English

# ── Lip Sync (RunComfy) ───────────────────────────────────────
RUNCOMFY_API_TOKEN=
RUNCOMFY_BASE_URL=https://model-api.runcomfy.net/v1

# ── Storage ────────────────────────────────────────────────────
GCS_BUCKET=ugc-clip-temp-files
S3_BUCKET=ugc-clip-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Identity Verification ─────────────────────────────────────
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# ── Image Generation ──────────────────────────────────────────
FAL_AI_KEY=
FAL_AI_BASE_URL=https://queue.fal.run
FAL_AI_IMAGE_MODEL=fal-ai/flux/schnell

# ── Billing ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Pipelines & Limits ─────────────────────────────────────────
MAX_TTS_CONCURRENT=1
MAX_LIPSYNC_CONCURRENT=3
MAX_OTHER_JOBS_CONCURRENT=5
COST_CAP_PER_PROJECT_USD=3.0
MIN_VOICE_SAMPLE_DURATION=15
MAX_SEGMENT_DURATION=15
MAX_PROJECT_RETRIES=3

# ── UGC Templates ─────────────────────────────────────────────
TEMPLATES_DIR=templates

# ── Local ──────────────────────────────────────────────────────
DATA_DIR=data
LOCAL_ASSET_DIR=local_assets
LOG_LEVEL=INFO
