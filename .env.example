# ── Server ──────────────────────────────────────────────────────
UGC_HOST=127.0.0.1
UGC_PORT=8000
UGC_SECRET_KEY=change-me-to-a-random-secret

# ── Database ───────────────────────────────────────────────────
UGC_DATABASE_URL=sqlite+aiosqlite:///data/ugc_clip.db
UGC_AUTO_CREATE_TABLES=true

# ── Auth ───────────────────────────────────────────────────────
UGC_JWT_ALGORITHM=HS256
UGC_JWT_EXPIRE_MINUTES=1440

# ── LLM ────────────────────────────────────────────────────────
UGC_OPENROUTER_API_KEY=
UGC_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
UGC_ANTHROPIC_API_KEY=
UGC_GEMINI_API_KEY=

# ── TTS (Qwen3-TTS on GCP GPU) ────────────────────────────────
UGC_GCP_PROJECT_ID=
UGC_GCP_ZONE=us-central1-a
UGC_GCP_MACHINE_TYPE=g2-standard-4
UGC_GCP_GPU_TYPE=nvidia-l4
UGC_GCP_GPU_COUNT=1
UGC_GCP_IMAGE_PROJECT=deeplearning-platform-release
UGC_GCP_IMAGE=pytorch-2-7-cu128-ubuntu-2204-nvidia-570-v20260129
UGC_QWEN_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-Base
UGC_QWEN_DTYPE=float32
UGC_QWEN_ATTN_IMPLEMENTATION=
UGC_QWEN_LANGUAGE=English

# ── Lip Sync (RunComfy) ───────────────────────────────────────
UGC_RUNCOMFY_API_TOKEN=
UGC_RUNCOMFY_BASE_URL=https://model-api.runcomfy.net/v1
UGC_TTS_PROVIDER=stub
UGC_LIPSYNC_PROVIDER=stub
UGC_EXTERNAL_PYTHON_BIN=python3
UGC_GOVCLIP_ROOT=/Volumes/Crucial X10/pcc-projects/canonical/projects/govclip
UGC_GOVCLIP_TTS_SCRIPT=/Volumes/Crucial X10/pcc-projects/canonical/projects/govclip/scripts/web_tts_job.py
UGC_GOVCLIP_LIPSYNC_SCRIPT=/Volumes/Crucial X10/pcc-projects/canonical/projects/govclip/scripts/web_lipsync_job.py

# ── Storage ────────────────────────────────────────────────────
UGC_GCS_BUCKET=ugc-clip-temp-files
UGC_S3_BUCKET=ugc-clip-uploads
UGC_AWS_ACCESS_KEY_ID=
UGC_AWS_SECRET_ACCESS_KEY=
UGC_AWS_REGION=us-east-1

# ── Identity Verification ─────────────────────────────────────
UGC_PERSONA_API_KEY=
UGC_PERSONA_TEMPLATE_ID=
UGC_PERSONA_WEBHOOK_SECRET=

# ── Image Generation ──────────────────────────────────────────
UGC_FAL_AI_KEY=
UGC_FAL_AI_BASE_URL=https://queue.fal.run
UGC_FAL_AI_IMAGE_MODEL=fal-ai/flux/schnell

# ── Billing ────────────────────────────────────────────────────
UGC_STRIPE_SECRET_KEY=
UGC_STRIPE_WEBHOOK_SECRET=
UGC_STRIPE_PRICE_PRO=
UGC_STRIPE_PRICE_AGENCY=

# ── Pipelines & Limits ─────────────────────────────────────────
UGC_MAX_TTS_CONCURRENT=1
UGC_MAX_LIPSYNC_CONCURRENT=3
UGC_MAX_OTHER_JOBS_CONCURRENT=5
UGC_COST_CAP_PER_PROJECT_USD=3.0
UGC_MIN_VOICE_SAMPLE_DURATION=15
UGC_MAX_SEGMENT_DURATION=15
UGC_MAX_PROJECT_RETRIES=3

# ── UGC Templates ─────────────────────────────────────────────
UGC_TEMPLATES_DIR=templates

# ── Local ──────────────────────────────────────────────────────
UGC_DATA_DIR=data
UGC_LOCAL_ASSET_DIR=local_assets
UGC_LOG_LEVEL=INFO
